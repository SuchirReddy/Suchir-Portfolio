generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Project {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  shortDescription String
  fullDescription  String
  githubUrl        String?
  liveUrl          String?
  featured         Boolean        @default(false)
  status           ProjectStatus  @default(DRAFT)
  displayOrder     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProjectImage[]
}

model ProjectImage {
  id           String  @id @default(cuid())
  projectId    String
  imageUrl     String
  displayOrder Int     @default(0)
  isCover      Boolean @default(false)
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Skill {
  id       String @id @default(cuid())
  name     String
  category String
  icon     String @default("Code2")
}

model JourneyMilestone {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  year             String
  date             DateTime?
  category         String
  shortDescription String
  longStory        String
  imageUrl         String?
  status           String    @default("Completed")
  displayOrder     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  metrics          String?
  linkUrl          String?
}

model JourneyStat {
  id           String @id @default(cuid())
  label        String
  value        String
  displayOrder Int    @default(0)
}

model JourneyLesson {
  id           String @id @default(cuid())
  title        String
  description  String
  displayOrder Int    @default(0)
}

model JourneySettings {
  id                String  @id @default(cuid())
  visionTitle       String  @default("Building products, systems, and AI experiences")
  visionSubtitle    String  @default("that help founders move faster.")
  visionDescription String?
  showProductMilestones Boolean @default(true)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  company   String?
  mobile    String?
}

model SiteSettings {
  id           String  @id @default(cuid())
  name         String  @default("Suchir Reddy")
  profileImage String?
  heroImage    String?
  tagline      String?
  github       String?
  linkedin     String?
  twitter      String?
  email        String?
  resumeUrl    String?
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
